# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Amazon Bedrock Models
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_EMBEDDINGS_MODEL_ID=amazon.nova-embed-text-v1

# DynamoDB
DYNAMODB_TABLE_NAME=fakenewsoff-analysis-cache
DYNAMODB_ENDPOINT=http://localhost:8000  # Optional: for local DynamoDB

# S3 Storage (Optional)
S3_INPUT_BUCKET=fakenewsoff-inputs
S3_OUTPUT_BUCKET=fakenewsoff-outputs

# Application Settings
NODE_ENV=development
LOG_LEVEL=info

# Demo Mode (for hackathon presentations)
DEMO_MODE=false
DEMO_DELAY=500
DEMO_LOG=false

# Cache Settings
CACHE_DISABLE=false
CACHE_TTL_HOURS=24
CACHE_MAX_SIZE=100
